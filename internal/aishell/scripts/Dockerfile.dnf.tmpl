ARG BASE_IMAGE={{.BaseImage}}
FROM ${BASE_IMAGE}

WORKDIR /work
USER root
ENV HOME=/root
ENV PATH="/root/.local/bin:${PATH}"
ENTRYPOINT []

RUN dnf -y install \
        bash curl ca-certificates tar gzip xz \
        openssh-clients git gh && \
    dnf clean all && \
    ARCH="$(uname -m)"; \
    case "$ARCH" in x86_64|amd64) ARCH=x64;; aarch64|arm64) ARCH=arm64;; esac && \
    curl -fsSL "https://nodejs.org/dist/v22.22.1/node-v22.22.1-linux-${ARCH}.tar.xz" \
        | tar -xJ --strip-components=1 -C /usr/local

CMD ["sh", "-c", "while true; do sleep 3600; done"]
